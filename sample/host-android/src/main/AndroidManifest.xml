<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required: the host downloads the guest .zipline bundle over HTTP.
         For dev (localhost serving) we allow cleartext via the network-security
         config below; production setups should use HTTPS and drop this. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="Konduit Sample"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <!-- Required by AndroidX Macrobenchmark — without it the
             cold-start metric reports "Cannot use without profileable
             application" on release-shape builds. `shell="true"` lets
             the system tracer attach to this process without ADB-side
             root. Safe to ship in release builds, but adopters who
             don't run benchmarks can drop this. -->
        <profileable
            android:shell="true"
            tools:targetApi="29"
            xmlns:tools="http://schemas.android.com/tools" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
